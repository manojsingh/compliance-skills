    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.0",
    "express": "^4.21.1",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.0",
    "playwright": "^1.58.2",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@types/pdfkit": "^0.17.5",
