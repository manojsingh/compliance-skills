{
  "name": "@compliance-portal/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp src/db/*.sql dist/db/",
    "start": "node dist/index.js",
