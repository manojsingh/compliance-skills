# Azure Service Principal Credentials
# DO NOT commit this file to source control!
# Copy this to .env.sp and fill in your actual credentials

export AZURE_CLIENT_ID="<your-service-principal-client-id>"
export AZURE_CLIENT_SECRET="<your-service-principal-client-secret>"
export AZURE_TENANT_ID="<your-azure-tenant-id>"
export AZURE_SUBSCRIPTION_ID="<your-subscription-id>"
export USE_SERVICE_PRINCIPAL="true"

# How to get these values:
# 1. Run: ./setup-service-principal.sh
# 2. Or manually create SP: az ad sp create-for-rbac --name "my-sp" --role Contributor
# 3. Save the output values to this file
