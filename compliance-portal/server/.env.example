# Environment Configuration

# Database Configuration
# For local development (SQLite) - leave DATABASE_URL empty
# For PostgreSQL - set these variables

# PostgreSQL Connection (choose one method)

# Method 1: Connection URL (recommended for development)
# DATABASE_URL=postgresql://username:password@localhost:5432/compliancedb

# Method 2: Individual environment variables
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=compliancedb
# PGUSER=postgres
# PGPASSWORD=yourpassword
# PGSSLMODE=require

# Method 3: Azure PostgreSQL with Managed Identity (passwordless)
# PGHOST=your-server.postgres.database.azure.com
# PGPORT=5432
# PGDATABASE=compliancedb
# PGUSER=your-managed-identity-name
# AZURE_POSTGRESQL_PASSWORDLESS=true
# AZURE_CLIENT_ID=your-managed-identity-client-id

# Server Configuration
PORT=3001
NODE_ENV=development

# Azure Configuration (for production deployment)
# APPLICATIONINSIGHTS_CONNECTION_STRING=your-app-insights-connection-string
# AZURE_CLIENT_ID=your-managed-identity-client-id
# AZURE_TENANT_ID=your-tenant-id

# Playwright Configuration
PLAYWRIGHT_BROWSERS_PATH=0
